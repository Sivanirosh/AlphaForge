# Database
DATABASE_URL=postgresql://alpha:alpha@localhost:5432/alphaforge

# Alpaca paper trading (free account: https://app.alpaca.markets/signup)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Comma-separated list of tickers to track
TICKERS=AAPL,MSFT,GOOGL,AMZN,META

# Rolling window size (trading days) for volatility and beta
ROLLING_WINDOW=60
